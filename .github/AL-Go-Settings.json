{
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go-Actions/v9.0/.Modules/settings.schema.json",
  "type": "PTE",
  "templateUrl": "https://github.com/microsoft/AL-Go-PTE@main",
  "repoVersion": "27.0",
  "versioningStrategy": 18,
  "cacheKeepDays": 9999,
  "enablePerTenantExtensionCop": true,
  "environments": [
    "BCBE-LIVE",
    "BCBE-UAT"    
  ],
  "DeployToBCBE-LIVE": {
    "EnvironmentType": "Cloud",
    "EnvironmentName": "BCBE-LIVE",
    "Scope": "PTE",
    "ContinuousDeployment": false,
    "runs-on": "DOCKER001",
    "Branches": [
      "Production"
    ]
  },
    "DeployToBCBE-UAT": {
    "EnvironmentType": "Cloud",
    "EnvironmentName": "BCBE-UAT",
    "Scope": "PTE",
    "ContinuousDeployment": false,
    "runs-on": "DOCKER001",
    "Branches": [
      "Accept"
    ]
  }
}
